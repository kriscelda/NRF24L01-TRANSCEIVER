#!/usr/bin/env python3
import evdev
from evdev import ecodes
import asyncio
import sys
import struct
import time
from pyrf24 import RF24, RF24_PA_LOW, RF24_250KBPS


# --- NRF24 CONFIGURATION ---
radio = RF24(25, 0)
STRUCT_FORMAT = 'iiii'
connection_status = {"connected": False, "success_count": 0, "fail_count": 0}


def setup_radio():

if not radio.begin():
        print("NRF ERROR: Check wiring (SPI/GPIO pins)!")
        return False
    radio.setChannel(76)
    radio.setDataRate(RF24_250KBPS)
    radio.setPALevel(RF24_PA_LOW)
    radio.setAutoAck(True)      # Ensure Auto-ACK is on for debugging
    radio.setRetries(5, 15)     # 5 retries, 15*250us delay
    radio.openWritingPipe(b"NODE2")
    radio.stopListening()
    return True


# --- PXN V99 CONFIGURATION ---
MAX_DEGREES = 450.0
WHEEL_DEVICE_NAME = "PXN PXN-V99"
GEAR_DEVICE_NAME  = "LiteStar"


state = {
    "steering_deg": 0.0,
    "gear": "Neutral",
    "throttle": 0,
    "brake": 0,
    "clutch": 0,
}


# --- HELPERS ---
def normalize_to_degrees(v, mi, ma):
    return round(((v - mi) / (ma - mi) * 2 - 1) * MAX_DEGREES, 1)


def normalize_percent(v, mi, ma):
    return int((v - mi) / (ma - mi) * 255)


# --- ASYNC TASKS ---


async def nrf_transmit_task():
    """Packs data and updates connection status based on ESP32 ACK"""
    while True:
        # Map steering to 0-180 for Servo
        steer_val = int((state["steering_deg"] + MAX_DEGREES) * (180 / (MAX_DEGREES * 2)))
       
        # G3=Forward(1), G4=Reverse(2), Neutral=0
        direction = 0
        if state["gear"] == "G3": direction = 1
        elif state["gear"] == "G4": direction = 2
       
        tx_data = struct.pack(STRUCT_FORMAT, steer_val, state["throttle"], direction, state["clutch"])
       
        # DEBUGGING: radio.write() returns True if ESP32 acknowledged the message
        result = radio.write(tx_data)
       
        if result:
            connection_status["connected"] = True
            connection_status["success_count"] += 1
        else:
            connection_status["connected"] = False
            connection_status["fail_count"] += 1
       
        await asyncio.sleep(0.05)


async def display_dashboard():
    """Prints steering data and NRF connection health"""
    while True:
        status_msg = "ONLINE" if connection_status["connected"] else "OFFLINE (No ACK)"
       
        out = (f"STR: {state['steering_deg']:>5}° | GAS: {state['throttle']:>3}% | "
               f"GEAR: {state['gear']:<5} | NRF: {status_msg} "
               f"(S:{connection_status['success_count']} F:{connection_status['fail_count']})")
       
        sys.stdout.write(f"\r{out}")
        sys.stdout.flush()
        await asyncio.sleep(0.1)

async def read_steering_and_pedals():
    dev = next((evdev.InputDevice(p) for p in evdev.list_devices() if evdev.InputDevice(p).name == WHEEL_DEVICE_NAME), None)
    if not dev: return
    abs_info = dict(dev.capabilities().get(ecodes.EV_ABS, []))
    async for event in dev.async_read_loop():
        if event.type == ecodes.EV_ABS and event.code in abs_info:
            info = abs_info[event.code]
            if event.code == ecodes.ABS_X: state["steering_deg"] = normalize_to_degrees(event.value, info.min, info.max)
            elif event.code == ecodes.ABS_Z: state["throttle"] = normalize_percent(event.value, info.min, info.max)
            elif event.code == ecodes.ABS_RZ: state["brake"] = normalize_percent(event.value, info.min, info.max)
            elif event.code == ecodes.ABS_THROTTLE: state["clutch"] = normalize_percent(event.value, info.min, info.max)


async def read_gear():
    dev = next((evdev.InputDevice(p) for p in evdev.list_devices() if GEAR_DEVICE_NAME.lower() in evdev.InputDevice(p).name.lower()), None)
    if not dev: return
    btns = {288: "G1", 289: "G2", 290: "G3", 291: "G4", 292: "G5", 293: "REV"}
    async for event in dev.async_read_loop():
        if event.type == ecodes.EV_KEY:
            state["gear"] = btns.get(event.code, "Neutral") if event.value > 0 else "Neutral"


async def main():
    if not setup_radio(): return
    print("Transmitter Active...")
    await asyncio.gather(read_steering_and_pedals(), read_gear(), display_dashboard(), nrf_transmit_task())


if __name__ == "__main__":
    try:
        asyncio.run(main())
    except KeyboardInterrupt:
        print("\nStopped.")
